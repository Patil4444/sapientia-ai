# Anthropic Claude API (required for AI incident analysis)
# Get a key at https://console.anthropic.com/settings/keys
# Keys start with sk-ant- — do NOT reuse GOOGLE_API_KEY from the Gemini migration.
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Optional: FastAPI backend URL when running uvicorn backend.main:app
# SAPIENTIA_API_URL=http://127.0.0.1:8000

# Legacy (no longer used by Sapientia — remove or leave commented after migration)
# GOOGLE_API_KEY=
